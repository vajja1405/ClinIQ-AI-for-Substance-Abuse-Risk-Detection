graph TD
    %% Styling
    classDef source fill:#ffffff,stroke:#2980b9,stroke-width:3px,color:#333
    classDef processing fill:#ffffff,stroke:#27ae60,stroke-width:3px,color:#333
    classDef model fill:#ffffff,stroke:#c0392b,stroke-width:3px,color:#333
    classDef output fill:#ffffff,stroke:#8e44ad,stroke-width:3px,color:#333

    %% Layer 1: Sources
    subgraph Data Sources
        A["<b>Kaggle Patient Reviews</b><br/>(52,184 Unstructured Texts)"]:::source
        B["<b>CDC & CMS Guidelines</b><br/>(ICD-10, DRG Severities)"]:::source
    end

